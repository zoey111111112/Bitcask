{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
            "name": "C++ Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}", // 对应编译出的二进制文件
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false, // 建议设为 false，直接在 VS Code 内部终端交互
            "MIMode": "lldb", // macOS 默认使用 lldb
            "preLaunchTask": "C/C++: clang++ 生成活动文件" // 必须和 tasks.json 中的 label 一致
        }
    ]
}